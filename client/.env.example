# Supabase Configuration
# You need to get these values from your Supabase project dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_API_URL=https://kasirent.onrender.com
# Optional comma-separated list of allowed registration email domains.
# Leave unset to keep the safe default: gmail.com,googlemail.com
VITE_EMAIL_ALLOWED_DOMAINS=gmail.com,googlemail.com

# Example:
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_API_URL=https://your-backend-api-domain.com
# VITE_EMAIL_ALLOWED_DOMAINS=gmail.com,googlemail.com